---
import HomeApp from "../components/home-app";
import "../styles/global.css";

export const prerender = false;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xookmarks - Curate the noise. Save the signal.</title>
    <meta
      name="description"
      content="Your personal gallery of high-signal Twitter embeds. Organized, searchable, and beautifully presented."
    />
    <script
      is:inline
      async
      src="https://platform.twitter.com/widgets.js"
      charset="utf-8"
    ></script>
  </head>
  <body>
    <HomeApp client:load />
  </body>
</html>
