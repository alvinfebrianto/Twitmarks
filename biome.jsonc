{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core", "ultracite/biome/astro"],
  "linter": {
    "rules": {
      "correctness": {
        "noUndeclaredVariables": "off"
      },
      "style": {
        "noNamespace": "off"
      }
    }
  },
  "files": {
    "includes": ["**/*", "!src/pages/index.astro"]
  }
}
